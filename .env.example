SCS_ENV=development
SCS_APP_NAME=semantic-code-search
SCS_API_PREFIX=/v1

SCS_SUPABASE_URL=https://your-project.supabase.co
SCS_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SCS_SUPABASE_SECRET_KEY=your-secret-key
SCS_SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SCS_SUPABASE_JWT_AUDIENCE=
SCS_SUPABASE_JWKS_CACHE_TTL_SECONDS=300
SCS_SUPABASE_STORAGE_BUCKET=repo-bundles

SCS_GITHUB_TOKEN=

SCS_EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v2-base-code
SCS_EMBEDDING_DIMENSIONS=768
SCS_EMBEDDING_DEVICE=
SCS_USE_STUB_EMBEDDINGS=true
SCS_EMBEDDING_BATCH_SIZE=16

SCS_JOB_WORKER_ENABLED=true
SCS_JOB_POLL_INTERVAL_SECONDS=3
SCS_GITHUB_CLONE_DEPTH=50
SCS_MAX_FILE_BYTES=200000
SCS_MAX_COMMIT_MESSAGES=200
